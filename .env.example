# Amass
AMASS_API_KEY=
# AMASS_API_BASE_URL=  # override default (https://api.amass.tech), e.g. for staging

# LiteLLM
LITELLM_BASE_URL=
LITELLM_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google
GOOGLE_GENERATIVE_AI_API_KEY=

# Model
MODEL=
# Examples:
# MODEL=litellm:gpt-4.1-mini
# MODEL=anthropic:claude-3-7-sonnet
# MODEL=openai:gpt-5
# MODEL=google:gemini-2.5-flash

# Dev-only escape hatch — bypass the env-var schema check entirely (env becomes {}).
# Useful when iterating on UI without provider keys. Never enable in production.
# SKIP_ENV_VALIDATION=true
